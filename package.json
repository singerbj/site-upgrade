{
  "name": "site-upgrade",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "sites/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "audit": "better-npm-audit audit --level high",
    "deploy:worker": "npm run deploy -w site-router",
    "deploy:site": "node --experimental-strip-types scripts/deploy-site.ts",
    "new-site": "node --experimental-strip-types scripts/new-site.ts",
    "changed-sites": "node --experimental-strip-types scripts/changed-sites.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "better-npm-audit": "^3.11.0",
    "oxfmt": "^0.4.0",
    "oxlint": "^0.15.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.7"
}
