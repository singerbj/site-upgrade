{
  "name": "site-upgrade",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "deploy:worker": "pnpm --filter site-router deploy",
    "deploy:site": "node --experimental-strip-types scripts/deploy-site.ts",
    "new-site": "node --experimental-strip-types scripts/new-site.ts",
    "changed-sites": "node --experimental-strip-types scripts/changed-sites.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  }
}
