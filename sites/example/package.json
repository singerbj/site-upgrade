{
  "name": "@sites/example",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build && rm -rf dist && mv out dist",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src"
  },
  "site": {
    "hostname": "example.example.com",
    "title": "Example Site",
    "description": "A Next.js static site hosted on Cloudflare via R2 + a router Worker."
  },
  "dependencies": {
    "@tanstack/react-pacer": "^0.6.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.13.0",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.0"
  }
}
