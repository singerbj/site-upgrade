# Per-site build-time configuration. Copy to .env.production and fill in
# the values you want baked into the static export.

# Google Analytics 4 measurement ID. If unset, the gtag scripts and the
# consent banner are not rendered. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Unsplash API access key (free tier: 50 req/hour). Required only if the
# site uses <UnsplashImage>. If unset, those components render nothing.
# Get one at https://unsplash.com/developers.
UNSPLASH_ACCESS_KEY=
