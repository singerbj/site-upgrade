{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/jsx-uses-react": "off",
    "no-await-in-loop": "off"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/.next/**",
    "**/out/**",
    "**/.turbo/**",
    "**/.wrangler/**",
    "**/node_modules/**"
  ]
}
