{
  "name": "@apps/scraper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Scrapes Google Maps for businesses, crawls their existing sites, runs Lighthouse, and scores design/quality with Mistral via the AI SDK. Output is a single source-controlled CSV used for dedup across runs.",
  "bin": {
    "scraper": "./src/cli.tsx"
  },
  "scripts": {
    "start": "tsx src/cli.tsx",
    "scrape": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@ai-sdk/mistral": "^1.1.0",
    "ai": "^4.0.0",
    "chrome-launcher": "^1.1.2",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "lighthouse": "^12.3.0",
    "playwright": "^1.49.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
